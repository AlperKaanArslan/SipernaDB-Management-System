@page "{id:int}"
@model SipernaWeb.Pages.PolicyDetailsModel
@{
    ViewData["Title"] = "Policy Detail Analysis";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 mb-4 bg-dark text-white p-4 rounded">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h6 class="text-info text-uppercase fw-bold mb-1" style="letter-spacing: 1px;">Policy Analysis</h6>
                <h2 class="fw-bold mb-0">Owner: @Model.PolicyRow["OwnerName"]</h2>
                <div class="mt-2">
                    <span class="badge bg-primary">Type: @Model.PolicyRow["PolicyType"]</span>
                    <span class="badge bg-secondary ms-2">ID: #@Model.PolicyRow["PolicyID"]</span>
                </div>
                @if (Model.PolicyRow["RenewalInfo"] != null)
                {
                    <p class="mt-3 mb-0 small text-light opacity-75 italic">
                        <i class="bi bi-info-circle me-1"></i> <strong>Renewal Note:</strong> @Model.PolicyRow["RenewalInfo"]
                    </p>
                }
            </div>
            <a href="/PolicyListModel" class="btn btn-outline-light btn-sm shadow-sm">Back to List</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-success text-white fw-bold py-3">
                    <i class="bi bi-people-fill me-2"></i>Beneficiaries (Family Members)
                </div>
                <div class="card-body">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr><th>Name</th><th class="text-center">Gender</th></tr>
                        </thead>
                        <tbody>
                            @foreach (System.Data.DataRow row in Model.Beneficiaries.Rows)
                            {
                                <tr>
                                    <td class="fw-bold">@row["FullName"]</td>
                                    <td class="text-center">
                                        <span class="badge @(row["Gender"].ToString() == "M" ? "bg-primary" : "bg-danger") rounded-pill">
                                            @row["Gender"]
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-7 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-info text-dark fw-bold py-3 d-flex justify-content-between">
                    <span><i class="bi bi-geo-alt-fill me-2"></i>Covered Providers & Network</span>
                    <span class="badge bg-white text-dark">@Model.Network.Rows.Count Total</span>
                </div>
                <div class="card-body" style="max-height: 500px; overflow-y: auto;">
                    @foreach (System.Data.DataRow row in Model.Network.Rows)
                    {
                        var typeCode = row["ProviderType"].ToString().Trim();
                        string typeName = "Other";
                        string badgeClass = "bg-secondary";
                        string icon = "bi-building";

                        if (typeCode == "H") { typeName = "Hospital"; badgeClass = "bg-danger"; icon = "bi-hospital"; }
                        else if (typeCode == "P") { typeName = "Pharmacy"; badgeClass = "bg-warning text-dark"; icon = "bi-capsule"; }
                        else if (typeCode == "L") { typeName = "Lab"; badgeClass = "bg-primary"; icon = "bi-thermometer-half"; }
                        else if (typeCode == "C") { typeName = "Clinic"; badgeClass = "bg-info text-dark"; icon = "bi-medical-services"; }

                        <div class="border-bottom mb-3 pb-2 hover-shadow-sm">
                            <div class="d-flex justify-content-between align-items-start">
                                <h6 class="mb-0 fw-bold">
                                    <i class="bi @icon me-2 text-muted"></i>@row["InstitutionName"]
                                </h6>
                                <span class="badge @badgeClass" style="font-size: 0.65rem;">@typeName</span>
                            </div>
                            <p class="text-muted mb-0 small ps-4">
                                <i class="bi bi-pin-map me-1 small"></i>@row["Address"]
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>