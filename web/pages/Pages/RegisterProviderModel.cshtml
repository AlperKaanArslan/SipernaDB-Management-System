@page
@model SipernaWeb.Pages.RegisterProviderModel
@{
    ViewData["Title"] = "Register Provider";
}

<div class="container mt-5">
    <div class="card shadow border-0 col-md-8 mx-auto">
        <div class="card-header bg-warning text-white p-3">
            <h4 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2"></i>Register New Provider</h4>
        </div>
        <div class="card-body p-4">
            <form method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">Institution Name</label>
                    <input type="text" asp-for="InstitutionName" class="form-control form-control-lg border-primary" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">Detailed Address</label>
                    <textarea asp-for="Address" class="form-control" rows="2" required></textarea>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-primary small">Email Addresses</label>
                        <div id="emailContainer">
                            <div class="input-group mb-2"><input type="email" name="Emails" class="form-control border-primary" placeholder="email@example.com" /></div>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="addItem('emailContainer', 'Emails', 'email')">+ Add Email</button>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-success small">Phone Numbers</label>
                        <div id="phoneContainer">
                            <div class="input-group mb-2"><input type="tel" name="Phones" class="form-control border-success" placeholder="+90..." /></div>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-success" onclick="addItem('phoneContainer', 'Phones', 'tel')">+ Add Phone</button>
                    </div>
                </div>

                <hr>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Category</label>
                        <select asp-for="ProviderType" class="form-select border-warning" id="typeSelect" onchange="toggleFields()" required>
                            <option value="" selected disabled>Select...</option>
                            <option value="H">Hospital</option>
                            <option value="C">Clinic</option>
                            <option value="L">Laboratory</option>
                            <option value="P">Pharmacy</option>
                        </select>
                    </div>
                    <div class="col-md-6 pt-4">
                        <div class="form-check p-3 bg-light border rounded shadow-sm ms-2">
                            <input type="checkbox" asp-for="ContractStatus" class="form-check-input ms-0" id="cCheck" checked>
                            <label class="form-check-label fw-bold ms-2" for="cCheck">Active Agreement</label>
                        </div>
                    </div>
                </div>

                <div id="hFields" class="sub-fields" style="display:none;">
                    <div class="row border p-3 rounded bg-light">
                        <div class="col-6 mb-3"><label class="form-label fw-bold">Bed Capacity</label><input type="number" asp-for="BedCapacity" class="form-control" /></div>
                        <div class="col-6 mb-3"><label class="form-label fw-bold">Discount Rate (%)</label><input type="number" step="0.01" asp-for="DiscountRate" class="form-control" /></div>
                    </div>
                </div>

                <div id="cFields" class="sub-fields" style="display:none;">
                    <div class="border p-3 rounded bg-light">
                        <label class="form-label fw-bold">Specialization Area</label>
                        <input type="text" asp-for="SpecializationArea" class="form-control" placeholder="e.g., Dental, Cardiology" />
                    </div>
                </div>

                <div id="lFields" class="sub-fields" style="display:none;">
                    <div class="row border p-3 rounded bg-light">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Response Time (Hours)</label>
                            <input type="number" asp-for="ResponseTimeHours" class="form-control" />
                        </div>
                        <div class="col-md-6 mt-4 pt-2 text-center">
                            <div class="form-check d-inline-block text-start">
                                <input type="checkbox" asp-for="HasHomeSampling" class="form-check-input" id="labCheck">
                                <label class="form-check-label fw-bold" for="labCheck">Home Sampling Available</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="pFields" class="sub-fields" style="display:none;">
                    <div class="border p-3 rounded bg-light text-center">
                        <label class="form-label fw-bold">Pharmacist Full Name</label>
                        <input type="text" asp-for="PharmacistFullName" class="form-control" placeholder="Pharmacist N&S" />
                    </div>
                </div>

                <div class="d-flex justify-content-between pt-3 border-top mt-4">
                    <a href="/ProviderListModel" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-warning text-white px-5 fw-bold shadow">Register Institution</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function addItem(containerId, name, type) {
            const container = document.getElementById(containerId);
            const div = document.createElement('div');
            div.className = 'input-group mb-2';
            div.innerHTML = `<input type="${type}" name="${name}" class="form-control border-${name === 'Emails' ? 'primary' : 'success'}" />
                             <button type="button" class="btn btn-outline-danger" onclick="this.parentElement.remove()">X</button>`;
            container.appendChild(div);
        }

        function toggleFields() {
            document.querySelectorAll('.sub-fields').forEach(f => f.style.display = 'none');

            const type = document.getElementById('typeSelect').value;
            if (type === 'H') document.getElementById('hFields').style.display = 'block';
            if (type === 'C') document.getElementById('cFields').style.display = 'block';
            if (type === 'L') document.getElementById('lFields').style.display = 'block';
            if (type === 'P') document.getElementById('pFields').style.display = 'block';
        }
    </script>
}