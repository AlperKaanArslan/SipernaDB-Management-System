@page
@model SipernaWeb.Pages.ProviderListModel
@{
    ViewData["Title"] = "Provider Network";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold text-primary">Provider Network</h1>
        <a href="/RegisterProviderModel" class="btn btn-warning text-white shadow-sm fw-bold">
            <i class="bi bi-plus-circle me-1"></i> Register New Provider
        </a>
    </div>

    <ul class="nav nav-tabs mb-4">
        <li class="nav-item"><a class="nav-link @(Model.Category == "H" ? "active fw-bold" : "")" asp-route-category="H">Hospitals</a></li>
        <li class="nav-item"><a class="nav-link @(Model.Category == "C" ? "active fw-bold" : "")" asp-route-category="C">Clinics</a></li>
        <li class="nav-item"><a class="nav-link @(Model.Category == "L" ? "active fw-bold" : "")" asp-route-category="L">Laboratories</a></li>
        <li class="nav-item"><a class="nav-link @(Model.Category == "P" ? "active fw-bold" : "")" asp-route-category="P">Pharmacies</a></li>
    </ul>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Institution Name</th>
                        @if (Model.Category == "H")
                        {
                            <th>Beds</th>
                            <th>Discount</th>
                        }
                        @if (Model.Category == "C")
                        {
                            <th>Specialization</th>
                        }
                        @if (Model.Category == "L")
                        {
                            <th>Response</th>
                            <th>Sampling</th>
                        }
                        @if (Model.Category == "P")
                        {
                            <th>Pharmacist</th>
                        }
                        <th>Registration Date</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (System.Data.DataRow row in Model.ProviderData.Rows)
                    {
                        <tr>
                            <td class="ps-3"><strong>@row["InstitutionName"]</strong></td>

                            @if (Model.Category == "H")
                            {
                                <td>@row["BedCapacity"]</td>
                                <td><span class="badge bg-success">@row["DiscountRate"]% Off</span></td>
                            }
                            @if (Model.Category == "C")
                            {
                                <td>@row["SpecializationArea"]</td>
                            }
                            @if (Model.Category == "L")
                            {
                                <td>@row["ResponseTimeHours"]h</td>
                                <td>
                                    <span class="badge @(Convert.ToBoolean(row["HasHomeSampling"]) ? "bg-info" : "bg-secondary")">
                                        @(Convert.ToBoolean(row["HasHomeSampling"]) ? "Home Svc" : "Lab Only")
                                    </span>
                                </td>
                            }
                            @if (Model.Category == "P")
                            {
                                <td>@row["PharmacistFullName"]</td>
                            }

                            <td class="small">@Convert.ToDateTime(row["InsertDate"]).ToShortDateString()</td>

                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-info"
                                            onclick="showDetails('@row["InstitutionName"]', '@row["Address"]', '@row["ContractStatus"]', '@Convert.ToDateTime(row["InsertDate"]).ToShortDateString()', '@row["TypeName"]', '@row["Emails"]', '@row["Phones"]')">
                                        Details
                                    </button>
                                    <a href="/EditProvider?id=@row["ProviderID"]&category=@Model.Category" class="btn btn-outline-primary">Edit</a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@row["ProviderID"]" onsubmit="return confirm('Delete record?');" style="display:inline;">
                                        <button class="btn btn-outline-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="detailsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-info text-white border-0">
                <h5 class="modal-title fw-bold" id="mTitle">Institution Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-4 text-center">
                    <i class="bi bi-building-check text-info" style="font-size: 2.5rem;"></i>
                    <h4 class="fw-bold mt-2 mb-0" id="mInstName"></h4>
                </div>

                <div class="mb-3">
                    <label class="text-muted small d-block mb-1 fw-semibold">Detailed Address</label>
                    <p class="border-start border-info border-3 ps-3 py-2 bg-light rounded-end" id="mAddress"></p>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6 border-end">
                        <h6 class="fw-bold small text-primary mb-2"><i class="bi bi-envelope-at me-2"></i>Email Addresses</h6>
                        <ul id="mEmails" class="list-unstyled small text-muted mb-0"></ul>
                    </div>
                    <div class="col-md-6 ps-3">
                        <h6 class="fw-bold small text-success mb-2"><i class="bi bi-telephone me-2"></i>Phone Numbers</h6>
                        <ul id="mPhones" class="list-unstyled small text-muted mb-0"></ul>
                    </div>
                </div>

                <div class="row g-2">
                    <div class="col-6">
                        <div class="p-2 border rounded bg-light text-center h-100">
                            <label class="text-muted small d-block fw-semibold">Partner Since</label>
                            <p class="fw-bold mb-0" id="mDate"></p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-2 border rounded bg-light text-center h-100">
                            <label class="text-muted small d-block fw-semibold">Agreement</label>
                            <div id="statusBadge" class="mt-1"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light border-0 p-3">
                <button type="button" class="btn btn-secondary w-100 fw-bold" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showDetails(name, address, status, date, type, emails, phones) {
            document.getElementById('mTitle').innerText = type + " Profile";
            document.getElementById('mInstName').innerText = name;
            document.getElementById('mAddress').innerText = address;
            document.getElementById('mDate').innerText = date;

            const mEmails = document.getElementById('mEmails');
            mEmails.innerHTML = (emails && emails !== 'null' && emails !== '')
                ? emails.split(',').map(e => `<li><i class="bi bi-dot"></i>${e.trim()}</li>`).join('')
                : '<li class="text-danger small italic">No email recorded</li>';

            const mPhones = document.getElementById('mPhones');
            mPhones.innerHTML = (phones && phones !== 'null' && phones !== '')
                ? phones.split(',').map(p => `<li><i class="bi bi-dot"></i>${p.trim()}</li>`).join('')
                : '<li class="text-danger small italic">No phone recorded</li>';

            const badgeDiv = document.getElementById('statusBadge');
            if (status === "True" || status === "1") {
                badgeDiv.innerHTML = '<span class="badge bg-success shadow-sm">Active Siperna Provider</span>';
            } else {
                badgeDiv.innerHTML = '<span class="badge bg-secondary shadow-sm">No Active Agreement</span>';
            }

            new bootstrap.Modal(document.getElementById('detailsModal')).show();
        }
    </script>
}