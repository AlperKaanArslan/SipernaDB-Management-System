@page
@model SipernaWeb.Pages.AddAgencyModel
<div class="container mt-4">
    <div class="card shadow border-0 mx-auto" style="max-width: 600px;">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0">Agency Registration</h5>
        </div>
        <div class="card-body p-4">
            <form method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold">Agency Name</label>
                    <input type="text" name="AgencyName" class="form-control" required maxlength="100">
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tax Number</label>
                        <input type="text" name="TaxNumber" class="form-control" required maxlength="10" placeholder="10 Digits">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Phone Number</label>
                        <input type="tel" name="PhoneNumber" class="form-control">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Email Address</label>
                    <input type="email" name="Email" class="form-control">
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Start Date</label>
                        <input type="date" name="StartDate" class="form-control" required value="@DateTime.Now.ToString("yyyy-MM-dd")">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">End Date (Optional)</label>
                        <input type="date" name="EndDate" class="form-control">
                    </div>
                </div>
                <hr>
                <div class="d-flex justify-content-between">
                    <a href="/AgencyList" class="btn btn-light">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Save Agency</button>
                </div>
            </form>
        </div>
    </div>
</div>
